# Database Configuration
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/photo_prestige

# JWT Configuration
JWT_SECRET=your-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h

# Environment
NODE_ENV=development
DEBUG=*

# Services Ports
AUTH_SERVICE_PORT=3001
REGISTER_SERVICE_PORT=3002
TARGET_SERVICE_PORT=3003
MAIL_SERVICE_PORT=3004
CLOCK_SERVICE_PORT=3005
SCORE_SERVICE_PORT=3006
READ_SERVICE_PORT=3007

# Service URLs (voor inter-service communicatie)
AUTH_SERVICE_URL=http://localhost:3001
REGISTER_SERVICE_URL=http://localhost:3002
TARGET_SERVICE_URL=http://localhost:3003
MAIL_SERVICE_URL=http://localhost:3004
CLOCK_SERVICE_URL=http://localhost:3005
SCORE_SERVICE_URL=http://localhost:3006
READ_SERVICE_URL=http://localhost:3007

# RabbitMQ Configuration
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# Imagga API Configuration (https://imagga.com)
# Signup for free account at: https://imagga.com/auth/signup/hacker
IMAGGA_API_KEY=your-imagga-api-key
IMAGGA_API_SECRET=your-imagga-api-secret
IMAGGA_API_URL=https://api.imagga.com/v2
IMAGGA_SIMILARITY_DISTANCE_THRESHOLD=1.4
IMAGGA_INDEX_NAME=photo_prestige_index

# Email Configuration
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@photo-prestige.local
MAIL_FROM_NAME=Photo Prestige

# SendGrid Alternative (uncomment to use)
# SENDGRID_API_KEY=your-sendgrid-api-key
# SENDGRID_FROM_EMAIL=noreply@photo-prestige.local

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800
ALLOWED_EXTENSIONS=jpg,jpeg,png,webp

# Cloud Storage (Azure Blob / AWS S3) - Optional
# AZURE_STORAGE_CONNECTION_STRING=
# AZURE_STORAGE_CONTAINER=photo-prestige
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-1
# AWS_S3_BUCKET=

# Gamification & Competition Settings
COMPETITION_DEFAULT_DURATION_HOURS=24
REMINDER_INTERVAL_HOURS=1
MIN_PARTICIPANT_SUBMISSIONS=2

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log

# CORS Configuration
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Feature Flags
FEATURE_EMAIL_NOTIFICATIONS=true
FEATURE_IMAGGA_SCORING=true
FEATURE_AUTO_WINNER_SELECTION=true
FEATURE_REMINDERS=true

# Monitoring & Tracing
ENABLE_MONITORING=false
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831

# Security
BCRYPT_ROUNDS=10
SESSION_SECRET=your-session-secret-change-this
